# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.tmp

# Node (web/ has its own .gitignore)
node_modules/

# Environment / Secrets
.env
.env.*
*.local.md
*.secret.md

# Data files (엑셀 등 대용량)
data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.spyproject/

# 크롤러/배치 실행 산출물 (로컬 실행시 생성되는 로그/에러/요약)
crawler/*.log
crawler/fill_coords_*.jsonl
crawler/fill_coords_*.json
crawler/fill_bjd_*.jsonl
crawler/fill_bjd_*.json
crawler/test_pnu_failures_*.jsonl

# 차단 탐지 테스트 산출물 (crawler/test/kepco_block_probe.py 결과)
crawler/test/results/

# 로컬 전용 런처 (시크릿 하드코딩 포함)
crawler/scripts/run_*_local.py

# 일반 테스트 스크립트 (시크릿 하드코딩 가능성)
scripts/test_*

# Cache 파일 (Actions 또는 로컬 fallback 으로 생성)
.cache/

# 편집기 tmp 파일
*.tmp.*

# Claude Code 로컬 런타임 (세션 캐시 등)
.claude/cp.json

# Windows bash crash dump
*.stackdump
