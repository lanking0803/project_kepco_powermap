# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.tmp

# Node (web/ has its own .gitignore)
node_modules/

# Environment / Secrets
.env
.env.*
*.local.md
*.secret.md

# Data files (엑셀 등 대용량)
data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.spyproject/

# 크롤러/배치 실행 산출물 (로컬 실행시 생성되는 로그/에러/요약)
crawler/*.log
crawler/fill_coords_*.jsonl
crawler/fill_coords_*.json
crawler/fill_bjd_*.jsonl
crawler/fill_bjd_*.json
crawler/test_pnu_failures_*.jsonl

# 로컬 전용 런처 (시크릿 하드코딩 포함)
crawler/run_*_local.py

# 테스트/검증 스크립트 (로컬 전용, 시크릿 하드코딩 가능성 있음)
scripts/test_*
crawler/test_*.py
# 단, 공매/경매 API 검증 스크립트는 재현성 위해 보존 (시크릿은 SECRETS.local.md 분리)
!crawler/test_onbid*.py
!crawler/test_hyphen*.py

# Cache 파일 (Actions 또는 로컬 fallback 으로 생성)
.cache/

# 편집기 tmp 파일
*.tmp.*

# Claude Code 로컬 런타임 (세션 캐시 등)
.claude/cp.json

# Windows bash crash dump
*.stackdump
